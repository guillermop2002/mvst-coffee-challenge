# =====================================================
# Funding Rate Arbitrage Bot - Environment Variables
# =====================================================
# Copy this file to .env and fill in your values.
# NEVER commit .env to git (already in .gitignore).
# =====================================================

# Exchange API credentials (only needed in Fase 6+)
# Generate at: https://www.binance.com/en/my/settings/api-management
# Permissions required: Read, Spot Trading, Futures Trading
# DO NOT enable Withdraw permission.
BINANCE_API_KEY=
BINANCE_API_SECRET=

# Use testnet for safety during initial live testing
# Testnet: https://testnet.binancefuture.com
BINANCE_TESTNET=true

# Bot operating mode: paper | testnet | live
BOT_MODE=paper

# Notifications (optional, recommended for live mode)
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
